# =============================================================================
# NuttX 链接命令模板（由 gen_link_template.py / copy_libs 根据 build.ninja / .config 生成）
# =============================================================================
# __ICS_SDK_ROOT__ = ICS SDK 根目录（libs 与 xpack-arm-none-eabi-gcc-* 的父目录）
# __ICS_CSHARP_OBJECT_PATH__ = 客户机 ILC 生成的 .o（仅此一项依赖客户路径）
# 已移除 -fmacro-prefix-map=（原为编译期路径映射，会含本机路径；链接静态库一般不需要）
# 说明见 link_placeholders.txt
#
# .config 中 CONFIG_ICS_NATIVEAOT_CSHARP_OBJECT_FILE_NAME 当前值（仅作文件名参考）: GpioForCSharpDriver.o
# =============================================================================

# --- 推荐：与构建一致，使用 SDK 内 arm-none-eabi-gcc 作为链接器前端 ---
LINK_CMD_GCC=__ICS_SDK_ROOT__/xpack-arm-none-eabi-gcc-13.3.1-1.1/bin/arm-none-eabi-gcc -o nuttx.elf --specs=nosys.specs -Wl,--print-memory-usage -Wl,--entry=__start -nostdlib -Wl,--gc-sections -Wl,--cref -Wl,-Map=nuttx.map -Wl,--wrap=_Unwind_RaiseException -Wl,--wrap=_Unwind_Resume -Wl,--wrap=_Unwind_ForcedUnwind -Wl,--wrap=_Unwind_Complete -Wl,--wrap=_Unwind_DeleteException -Wl,--wrap=_Unwind_GetRegionStart -Wl,--wrap=_Unwind_GetLanguageSpecificData -Wl,--wrap=_Unwind_VRS_Get -Wl,--wrap=_Unwind_VRS_Set -Wl,--wrap=_Unwind_VRS_Pop -Wl,--wrap=__gnu_unwind_frame -Wl,--wrap=__aeabi_unwind_cpp_pr0 -mtune=cortex-m7 -march=armv7e-m -mfpu=fpv5-d16 -mfloat-abi=hard --param=min-pagesize=0 -fno-common -Wall -Wshadow -Wundef -nostdlib -fno-omit-frame-pointer -fno-optimize-sibling-calls -funwind-tables -fasynchronous-unwind-tables -mthumb -Wa,-mthumb -Wa,-mimplicit-it=always -ffunction-sections -fdata-sections -g -Wno-attributes -Wno-unknown-pragmas -Wstrict-prototypes -fno-short-enums -Wno-psabi -fdiagnostics-color=always -T __ICS_SDK_ROOT__/libs/flash_app_flat.ld.tmp -Wl,--start-group __ICS_SDK_ROOT__/libs/arch/libarch.a __ICS_SDK_ROOT__/libs/binfmt/libbinfmt.a __ICS_SDK_ROOT__/libs/drivers/libdrivers.a __ICS_SDK_ROOT__/libs/fs/libfs.a __ICS_SDK_ROOT__/libs/libs/libc/libc.a __ICS_SDK_ROOT__/libs/mm/libmm.a __ICS_SDK_ROOT__/libs/net/libnet.a __ICS_SDK_ROOT__/libs/sched/libsched.a __ICS_SDK_ROOT__/libs/boards/libboard.a __ICS_SDK_ROOT__/libs/libs/libxx/libcxx/liblibcxx.a __ICS_SDK_ROOT__/libs/libs/libxx/libcxxabi/liblibcxxabi.a __ICS_SDK_ROOT__/libs/apps/libapps.a __ICS_SDK_ROOT__/libs/apps/ics/Common/libics_csharp_pinvoke.a __ICS_SDK_ROOT__/libs/apps/ics/EmbedXrpc/libembedxrpc.a __ICS_SDK_ROOT__/libs/apps/ics/NativeAot/libnativeaot_loader.a __ICS_SDK_ROOT__/libs/apps/system/dd/libapps_dd.a __ICS_SDK_ROOT__/libs/apps/system/nsh/libapps_nsh.a __ICS_SDK_ROOT__/libs/apps/system/nsh/libapps_sh.a __ICS_SDK_ROOT__/libs/apps/examples/hello/libapps_hello.a __ICS_SDK_ROOT__/xpack-arm-none-eabi-gcc-13.3.1-1.1/lib/gcc/arm-none-eabi/13.3.1/thumb/v7e-m+dp/hard/libgcc.a __ICS_SDK_ROOT__/xpack-arm-none-eabi-gcc-13.3.1-1.1/arm-none-eabi/lib/thumb/v7e-m+dp/hard/libm.a __ICS_SDK_ROOT__/aot_runtime/build_flat/libllvm_libunwind.a __ICS_SDK_ROOT__/aot_runtime/build_flat/libnativeaot.a __ICS_SDK_ROOT__/aot_runtime/build_flat/libnativeaot_asm.a __ICS_SDK_ROOT__/aot_runtime/build_flat/libopenssl.a __ICS_SDK_ROOT__/aot_runtime/build_flat/libSystem_Native.a __ICS_SDK_ROOT__/aot_runtime/build_flat/libSystem_Net_Security_Native_Nuttx.a __ICS_SDK_ROOT__/aot_runtime/build_flat/libSystem_Security_Cryptography_Native.a __ICS_SDK_ROOT__/aot_runtime/build_flat/libnuttx_sharp.a __ICS_SDK_ROOT__/aot_runtime/build_flat/libSystem_IO_Compression_Native.a __ICS_SDK_ROOT__/aot_runtime/build_flat/libBrotli.a __ICS_CSHARP_OBJECT_PATH__ -Wl,--end-group

# libgcc/libm 等已写为 __ICS_SDK_ROOT__/xpack-arm-none-eabi-gcc-*/...，与随包工具链目录一致。
# NativeAot 静态库已写为 __ICS_SDK_ROOT__/aot_runtime/build_flat/<name>.a；请将 build_flat 中对应 .a 放入该相对路径（相对 ICS SDK 根）。
# 唯一客户机路径占位：__ICS_CSHARP_OBJECT_PATH__（ILC 生成的 .o；文件名可参考 .config 中 CONFIG_ICS_NATIVEAOT_CSHARP_OBJECT_FILE_NAME）。

# --- 若必须使用 arm-none-eabi-ld：需把 -Wl,xxx 改为 ld 的 xxx ---

# --- 原始 LINK_LIBRARIES（仅供参考）---
