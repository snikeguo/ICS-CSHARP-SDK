# --- 原始 LINK_FLAGS ---
# LINK_FLAGS=--specs=nosys.specs -Wl,--print-memory-usage -Wl,--entry=__start -nostdlib -Wl,--gc-sections -Wl,--cref -Wl,-Map=nuttx.map
