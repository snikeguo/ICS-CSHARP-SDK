MEMORY
{
  flash (rx) : ORIGIN = 0xC0000000+0x1000, LENGTH = 24M -0x1000
  ram (rwx) : ORIGIN = 0xC0000000+24M, LENGTH = 40M
}
OUTPUT_ARCH(arm)
EXTERN(_vectors)
ENTRY(start)
BOOT_IMAGE_START = 0x08000000;
APP_IMAGE_START = 0xC0000000;
SECTIONS
{
    .text :
    {
        _stext = ABSOLUTE(.);
        KEEP(*(.userspace))
        *(.vectors)
        *(.text .text.*)
        __start___managedcode = .;
        *(__managedcode)
        __stop___managedcode = .;
        __start___unbox = .;
        *(__unbox)
        __stop___unbox = .;
       *(.text.thunks)
        *(.fixup)
        *(.gnu.warning)
        *(.rodata .rodata.*)
        *(.gnu.linkonce.t.*)
        *(.glue_7)
        *(.glue_7t)
        *(.got)
        *(.gcc_except_table)
        *(.gnu.linkonce.r.*)
        . = ALIGN(4);
        __start___modules = .;
        KEEP(*(__modules))
        __stop___modules = .;
    } > flash
    .preinit_array :
    {
        . = ALIGN(4);
        PROVIDE_HIDDEN (__preinit_array_start = .);
        KEEP (*(.preinit_array*))
        PROVIDE_HIDDEN (__preinit_array_end = .);
        . = ALIGN(4);
    } >flash
    .init_section :
    {
        _sinit = ABSOLUTE(.);
        KEEP(*(SORT_BY_INIT_PRIORITY(.init_array.*) SORT_BY_INIT_PRIORITY(.ctors.*)))
        KEEP(*(.init_array EXCLUDE_FILE(*crtbegin.o *crtbegin?.o *crtend.o *crtend?.o) .ctors))
        _einit = ABSOLUTE(.);
    } > flash
    .fini_array :
    {
        . = ALIGN(4);
        PROVIDE_HIDDEN (__fini_array_start = .);
        KEEP (*(SORT(.fini_array.*)))
        KEEP (*(.fini_array*))
        PROVIDE_HIDDEN (__fini_array_end = .);
        . = ALIGN(4);
    } >flash
    .tdata : {
        _stdata = ABSOLUTE(.);
        *(.tdata .tdata.* .gnu.linkonce.td.*);
        _etdata = ABSOLUTE(.);
    } > flash
    .tbss : {
        _stbss = ABSOLUTE(.);
        *(.tbss .tbss.* .gnu.linkonce.tb.* .tcommon);
        _etbss = ABSOLUTE(.);
    } > flash
    .eh_frame :
    {
        __eh_frame_start = .;
        KEEP (*(.eh_frame))
        __eh_frame_end = .;
    } > flash
    .eh_frame_hdr :
    {
        __eh_frame_hdr_start = .;
        KEEP (*(.eh_frame_hdr))
        __eh_frame_hdr_end = .;
    } > flash
    .ARM.extab :
    {
          __extab_managedcode_start = ABSOLUTE(.);
         *(.ARM.extab* .gnu.linkonce.armextab.*)
         __extab_managedcode_end = ABSOLUTE(.);
    } > flash
    .ARM.exidx :
    {
         __exidx_start = ABSOLUTE(.);
         __exidx_managedcode_start = ABSOLUTE(.);
          *(.ARM.exidx* .gnu.linkonce.armexidx.*)
         __exidx_managedcode_end = ABSOLUTE(.);
         __exidx_end = ABSOLUTE(.);
    } > flash
     _etext = ABSOLUTE(.);
    _eronly = ABSOLUTE(.);
    .data :
    {
        _sdata = ABSOLUTE(.);
        *(.data .data.*)
        *(.gnu.linkonce.d.*)
        CONSTRUCTORS
        . = ALIGN(4);
        _edata = ABSOLUTE(.);
    } > ram AT > flash
    .bss :
    {
         _sbss = ABSOLUTE(.);
        __hydrated_start = .;
        *(.hydrated)
        __hydrated_end = .;
        *(.bss .bss.*)
        *(.gnu.linkonce.b.*)
        *(COMMON)
        . = ALIGN(4);
        _ebss = ABSOLUTE(.);
    } > ram
    __ram_end = ORIGIN(ram) + LENGTH(ram) - 1;
    .stab 0 : { *(.stab) }
    .stabstr 0 : { *(.stabstr) }
    .stab.excl 0 : { *(.stab.excl) }
    .stab.exclstr 0 : { *(.stab.exclstr) }
    .stab.index 0 : { *(.stab.index) }
    .stab.indexstr 0 : { *(.stab.indexstr) }
    .comment 0 : { *(.comment) }
    .debug_abbrev 0 : { *(.debug_abbrev) }
    .debug_info 0 : { *(.debug_info) }
    .debug_line 0 : { *(.debug_line) }
    .debug_pubnames 0 : { *(.debug_pubnames) }
    .debug_aranges 0 : { *(.debug_aranges) }
    .ARM.attributes 0 : { *(.ARM.attributes) }
}
