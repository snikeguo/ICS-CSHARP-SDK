root = true

[*.cs]
charset = utf-8
indent_style = space
indent_size = 4
end_of_line = crlf

# C# coding conventions
# Use PascalCase for types, enum members, public properties and public fields
# Use _camelCase for private fields

# Symbol groups
dotnet_naming_symbols.types = kind: class, struct, interface, enum, delegate
dotnet_naming_symbols.enum_members = kind: enum, access: public
dotnet_naming_symbols.public_properties = kind: property, accessibility: public
dotnet_naming_symbols.public_fields = kind: field, accessibility: public
dotnet_naming_symbols.private_fields = kind: field, accessibility: private

# Naming styles
dotnet_naming_style.pascal_case.capitalization = pascal_case
dotnet_naming_style.camel_case.capitalization = camel_case
dotnet_naming_style._underscore_prefix.required_prefix = _

# Rules
dotnet_naming_rule.types_should_be_pascal.symbols = types
dotnet_naming_rule.types_should_be_pascal.style = pascal_case
dotnet_naming_rule.types_should_be_pascal.severity = warning

dotnet_naming_rule.enum_members_should_be_pascal.symbols = enum_members
dotnet_naming_rule.enum_members_should_be_pascal.style = pascal_case
dotnet_naming_rule.enum_members_should_be_pascal.severity = warning

dotnet_naming_rule.public_properties_should_be_pascal.symbols = public_properties
dotnet_naming_rule.public_properties_should_be_pascal.style = pascal_case
dotnet_naming_rule.public_properties_should_be_pascal.severity = warning

dotnet_naming_rule.public_fields_should_be_pascal.symbols = public_fields
dotnet_naming_rule.public_fields_should_be_pascal.style = pascal_case
dotnet_naming_rule.public_fields_should_be_pascal.severity = suggestion

dotnet_naming_rule.private_fields_should_have_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_should_have_underscore.style = _underscore_prefix
dotnet_naming_rule.private_fields_should_have_underscore.severity = suggestion

# Prefer language keywords
csharp_style_predefined_type_for_locals_parameters_members = true:suggestion
csharp_style_predefined_type_for_member_access = true:suggestion